# Server
PORT=3000

# JWT secret (generate with: openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here

# S3 / LocalStack (used by fileuploader)
S3_BUCKET=orbit-project-assets
S3_ENDPOINT=http://localhost:4566

# Max upload size in MB (integer)
MAX_FILE_SIZE=100

# AWS credentials for local testing (floci / localstack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# (Optional) DynamoDB local endpoint
DYNAMO_ENDPOINT=http://localhost:4566
